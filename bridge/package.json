{
  "name": "@maxgravity/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Windows bridge for the Maxgravity iPhone companion app.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "security:audit": "npm audit --audit-level=high",
    "secret-scan": "node scripts/secret-scan.mjs",
    "bridge:doctor": "tsx src/pair-tool.ts doctor",
    "bridge:start": "tsx src/pair-tool.ts start",
    "bridge:pair": "tsx src/pair-tool.ts pair",
    "bridge:status": "tsx src/pair-tool.ts status",
    "bridge:stop": "tsx src/pair-tool.ts stop",
    "bridge:devices": "tsx src/pair-tool.ts devices",
    "bridge:revoke-device": "tsx src/pair-tool.ts revoke"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.6.2",
    "pino": "^10.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
